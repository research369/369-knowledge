# 369 Research Knowledge API — Umgebungsvariablen
# Kopiere diese Datei zu .env und fülle alle Werte aus
# NIEMALS .env committen!

# ─── Datenbank ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/knowledge_db

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=change_me_min_16_chars
JWT_SECRET=change_me_random_32_chars_minimum

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
CORS_ORIGIN=http://localhost:5174
NODE_ENV=development
