# ─── 369 Knowledge OS — Backend Environment Variables ─────────────────────────
#
# ANLEITUNG:
# 1. Kopiere diese Datei: cp .env.example .env
# 2. Fülle alle Pflichtfelder aus
# 3. NIEMALS .env committen — sie ist in .gitignore
# 4. Für Production: Setze alle Variablen direkt in Railway unter "Variables"
#
# SICHERHEITSHINWEISE:
# - Niemals API Keys im Chat oder in Commit-Messages posten
# - Niemals Keys in Logs ausgeben
# - Niemals Keys committen
# ─────────────────────────────────────────────────────────────────────────────

# ─── Datenbank (Pflicht) ──────────────────────────────────────────────────────
# Railway PostgreSQL Connection String
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/knowledge_os

# ─── Admin Authentication (Pflicht) ──────────────────────────────────────────
# Sicheres Passwort für den Admin-Bereich
# Mindestens 16 Zeichen, Groß-/Kleinbuchstaben, Zahlen, Sonderzeichen
ADMIN_PASSWORD=change-me-to-a-secure-password
JWT_SECRET=change-me-to-a-random-secret-string-min-32-chars

# ─── LLM Provider — Knowledge Factory (Pflicht für Factory) ──────────────────
# Ohne gültigen Key läuft das System weiter, aber die Factory ist deaktiviert.
# Der Key muss direkt in Railway unter Variables gesetzt werden.
# NIEMALS im Chat posten. NIEMALS committen.
#
# Anleitung Railway:
# 1. Railway Dashboard → Projekt → Backend-Service
# 2. Variables → New Variable
# 3. Name: OPENAI_API_KEY, Value: sk-...
# 4. Deploy wird automatisch getriggert
OPENAI_API_KEY=

# LLM Provider (Standard: openai, später austauschbar gegen anthropic, mistral etc.)
LLM_PROVIDER=openai

# OpenAI Model
# gpt-4o-mini  = Kosten-effizient, gut für Standard-Generierung
# gpt-4o       = Höchste Qualität, empfohlen für Goldstandard-Entities
OPENAI_MODEL=gpt-4o-mini

# Factory komplett deaktivieren ohne Key zu entfernen (true/false)
FACTORY_LLM_ENABLED=true

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Frontend-URL(s), kommagetrennt
CORS_ORIGIN=http://localhost:5174,https://your-netlify-app.netlify.app
